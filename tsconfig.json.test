{
  "compilerOptions": {
    "esModuleInterop": true,
    "allowJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./types",
    "rootDir": "./",
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "lib": ["dom", "dom.iterable", "esnext"],
  },
  "include": ["configs/*.js", "index.js","prettier.js"], // Point to your JavaScript source files
  "exclude": ["node_modules", "starters"]
}
